    <link href="https://minhhungit.github.io/2019/09/26/002-how-to-create-slider-dialog-in-serenity-part-1/"/>
    <id>https://minhhungit.github.io/2019/09/26/002-how-to-create-slider-dialog-in-serenity-part-1/</id>
